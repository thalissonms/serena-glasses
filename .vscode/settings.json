{
    "i18n-ally.localesPaths": [
        "i18n/locales",
        "i18n",
        "coverage/serena-glasses/i18n",
        "coverage/serena-glasses/i18n/locales"
    ],
    "i18n-ally.sourceLanguage": "en-US",
    "i18n-ally.displayLanguage": "pt-BR",
    "i18n-ally.keystyle": "nested",
    "i18n-ally.namespace": true,
    "editor.quickSuggestions": {
        "other": true,
        "comments": false,
        "strings": true
    },
    "tailwindCSS.includeLanguages": {
        "typescriptreact": "html",
        "javascriptreact": "html",
        "scss": "css"
    },
    "tailwindCSS.emmetCompletions": true,
    "tailwindCSS.validate": true,
    "tailwindCSS.trace": "verbose",
    "tailwindCSS.files.exclude": [
        "**/.git/**",
        "**/node_modules/**",
        "**/.next/**",
        "**/dist/**"
    ],
    "tailwindCSS.experimental.classRegex": [
        ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["classVarianceAuthority\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["clsx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["cx\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
        ["cva\\([^)]*\\).*?\\{([^}]*)\\}", "[\"'`]([^\"'`]*).*?[\"'`]"]
    ],
    "css.validate": false,
    "scss.validate": false,
    "editor.inlineSuggest.enabled": true,
    "workbench.colorCustomizations": {
        "activityBar.background": "#5C0042",
        "titleBar.activeBackground": "#81005C",
        "titleBar.activeForeground": "#FFF9FD",
        "titleBar.inactiveBackground": "#5C0042",
        "titleBar.inactiveForeground": "#FFF9FD",
        "statusBar.debuggingBackground": "#271820",
        "statusBar.debuggingForeground": "#FFF8FC",
        "statusBar.noFolderBackground": "#271820",
        "statusBar.noFolderForeground": "#FFF8FC",
        "statusBar.background": "#334e99",
        "statusBar.foreground": "#ffffff",
        "sash.hoverBorder": "#334e99"
    },
    "windowColors.🌈 BaseColor": "#FF00B6"
}