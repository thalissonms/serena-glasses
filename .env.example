# ======================
# Ambiente de Exemplo
# Copie este arquivo para .env.local (gitignored) para desenvolvimento.
# Variáveis NEXT_PUBLIC_ ficam disponíveis no client.
# Variáveis sem NEXT_PUBLIC_ só no servidor.
# ======================

# ---- App Base ----
NEXT_PUBLIC_APP_NAME="Serena Glasses"
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Em produção coloque o domínio final (sem barra no final).
# Em dev deixe vazio ou http://localhost:3000 (webhooks locais precisam de ngrok).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_ENV=development

# ---- Internacionalização ----
# Lista de locales suportados (se alterar precisa rebuild)
NEXT_PUBLIC_I18N_LOCALES=pt-BR,en-US,es-ES
# Locale padrão
NEXT_PUBLIC_I18N_DEFAULT_LOCALE=pt-BR

# ---- Analytics / Monitoramento (preencher quando integrar) ----
# NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN= # (somente servidor / CI)

# ---- Feature Flags (exemplos) ----
# NEXT_PUBLIC_FEATURE_NEW_HEADER=false
# NEXT_PUBLIC_FEATURE_EXPERIMENTAL_UI=false

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NUNCA expor essa key no client — somente API Routes server-side
NEXT_PUBLIC_SUPABASE_ANON_KEY=changeme-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=changeme-supabase-service-role-key

# ---- API Externa / Backend ----
# Exemplo de endpoint de API
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Token secreto ou chave privada (não prefixar com NEXT_PUBLIC_)
API_INTERNAL_SECRET=changeme-dev-secret

# ---- Segurança / CSP Dinâmica (se for gerar hashes nonces) ----
# CSP_ENABLE=1

# ---- Build / Performance ----
# FORCE_SW_MINIFY=true

# ---- Imagens Remotas adicionais (se quiser sobrescrever via runtime build) ----
# REMOTE_IMAGES_EXTRA=cdn.otro-dominio.com,media.example.org

# ---- E-mail / Resend (server-side apenas) ----
# Criar conta em https://resend.com e gerar API key.
RESEND_API_KEY=re_changeme
# Endereço remetente — domínio deve estar verificado no Resend.
RESEND_FROM_EMAIL=onboarding@resend.dev

# ---- Admin Panel (server-only) ----
# Lista de e-mails autorizados a acessar /admin (separados por vírgula).
# Apenas usuários do Supabase Auth com e-mail nesta lista têm acesso.
ADMIN_EMAILS=admin@serenaglasses.com

# ---- Melhor Envio ----
# Criar conta em https://melhorenvio.com.br + ativar sandbox em https://sandbox.melhorenvio.com.br
# Painel → "Aplicativos" → criar app → anotar client_id e client_secret
MELHOR_ENVIO_ENV=sandbox
MELHOR_ENVIO_USER_AGENT="Serena Glasses (contato@serenaglasses.com)"
MELHOR_ENVIO_CLIENT_ID=
MELHOR_ENVIO_CLIENT_SECRET=
MELHOR_ENVIO_WEBHOOK_SECRET=

# ---- Endereço da loja (remetente nas etiquetas) ----
STORE_NAME="Serena Glasses"
STORE_DOCUMENT=          # CNPJ (somente números)
STORE_EMAIL=
STORE_PHONE=
STORE_CEP=
STORE_STREET=
STORE_NUMBER=
STORE_COMPLEMENT=
STORE_DISTRICT=
STORE_CITY=
STORE_STATE=             # UF (2 letras)
STORE_PACKAGE_WIDTH_CM=24
STORE_PACKAGE_HEIGHT_CM=4
STORE_PACKAGE_LENGTH_CM=16
STORE_PACKAGE_WEIGHT_G=110

# ---- Frete grátis fixo por cidade ----
# slug: lowercase, sem acento, espaços/pontuação → -, formato cidade-uf
FREE_SHIPPING_CITIES=congonhas-mg,sao-joao-del-rei-mg

# ---- Cron / Expiração de pedidos ----
# Qualquer string secreta — Vercel injeta automaticamente como Bearer token
# ao disparar os crons configurados em vercel.json.
CRON_SECRET=changeme-cron-secret

# ---- Rate Limiting / Upstash Redis ----
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=changeme-upstash-token

# ---- Outros ----
# LOG_LEVEL=debug

# ---- Pagamentos / Mercado Pago ----
# Chave privada do Mercado Pago (server-only)
# Obter em: https://www.mercadopago.com.br/developers/panel
MP_ACCESS_TOKEN=changeme-mp-access-token
# Chave pública do Mercado Pago (client-side)
NEXT_PUBLIC_MP_PUBLIC_KEY=changeme-mp-public-key
# Secret para validação HMAC dos webhooks do MP.
MP_WEBHOOK_SECRET=changeme-mp-webhook-secret
